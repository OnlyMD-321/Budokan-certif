generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Gender {
  MALE
  FEMALE
}

enum ChampionshipType {
  REGIONAL
  NATIONAL
}

enum ChampionshipStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  APPROVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum MedalType {
  GOLD
  SILVER
  BRONZE
}

enum CertificateDiscipline {
  JUJITSU
  AIKIDO
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Athlete {
  id                String         @id @default(uuid())
  fullName          String
  dateOfBirth       DateTime
  gender            Gender
  currentWeight     Float?
  heightCm          Float?
  clubName          String
  phone             String?
  emergencyContact  String?
  photoUrl          String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  registrations     Registration[]
  certificates      Certificate[]
  medals            Medal[]
}

model Championship {
  id                 String         @id @default(uuid())
  name               String
  league             String         @default("Casablanca Cedar League")
  type               ChampionshipType @default(REGIONAL)
  status             ChampionshipStatus @default(DRAFT)
  eventDate          DateTime
  location           String
  enabledDisciplines Json
  pricing            Json
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  registrations      Registration[]
  certificates       Certificate[]
  medals             Medal[]
}

model Registration {
  id                String             @id @default(uuid())
  athleteId         String
  championshipId    String
  selectedDisciplines Json
  ageGroup          String
  weightCategory    String
  tuitionAmount     Int
  status            RegistrationStatus @default(PENDING)
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  athlete           Athlete            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  championship      Championship       @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  payment           Payment?
}

model Payment {
  id                String         @id @default(uuid())
  registrationId    String         @unique
  amountDue         Int
  amountPaid        Int            @default(0)
  status            PaymentStatus  @default(UNPAID)
  paidAt            DateTime?
  note              String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  registration      Registration   @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Medal {
  id                String       @id @default(uuid())
  athleteId         String
  championshipId    String
  categoryLabel     String
  placement         Int
  medalType         MedalType
  createdAt         DateTime     @default(now())
  athlete           Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  championship      Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
}

model Certificate {
  id                String                 @id @default(uuid())
  athleteId         String?
  championshipId    String?
  studentName       String
  rank              String
  date              DateTime               @default(now())
  location          String                 @default("Casablanca, Maroc")
  discipline        CertificateDiscipline  @default(JUJITSU)
  createdAt         DateTime               @default(now())
  athlete           Athlete?               @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  championship      Championship?          @relation(fields: [championshipId], references: [id], onDelete: SetNull)
}

model Notification {
  id                String            @id @default(uuid())
  type              NotificationType  @default(INFO)
  title             String
  message           String
  entityType        String?
  entityId          String?
  isRead            Boolean           @default(false)
  createdAt         DateTime          @default(now())
  readAt            DateTime?
}

model ActivityLog {
  id                String   @id @default(uuid())
  action            String
  entityType        String
  entityId          String?
  summary           String
  details           Json?
  createdAt         DateTime @default(now())
}
